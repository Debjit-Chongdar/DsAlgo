✅ Custom Collector Class (Top 3 Orders)
import java.util.*;
import java.util.function.*;
import java.util.stream.Collector;

public class Top3OrderCollector implements Collector<Order, List<Order>, List<Order>> {

    @Override
    public Supplier<List<Order>> supplier() {
        return ArrayList::new;
    }

    @Override
    public BiConsumer<List<Order>, Order> accumulator() {
        return (list, order) -> {
            list.add(order);
            list.sort(Comparator.comparingInt(Order::getOrder_count).reversed());
            if (list.size() > 3) {
                list.remove(list.size() - 1);
            }
        };
    }

    @Override
    public BinaryOperator<List<Order>> combiner() {
        return (list1, list2) -> {
            list1.addAll(list2);
            list1.sort(Comparator.comparingInt(Order::getOrder_count).reversed());
            return list1.size() > 3 ? list1.subList(0, 3) : list1;
        };
    }

    @Override
    public Function<List<Order>, List<Order>> finisher() {
        return list -> list; // identity
    }

    @Override
    public Set<Characteristics> characteristics() {
        return Collections.emptySet();
    }
}

public class GroupingCollector implements Collector<Order, Map<Integer, List<Order>>, Map<Integer, List<Order>>> {

    @Override
    public Supplier<Map<Integer, List<Order>>> supplier() {
        return HashMap::new;
    }

    @Override
    public BiConsumer<Map<Integer, List<Order>>, Order> accumulator() {
        return (map, order) -> {
            map.computeIfAbsent(order.getCountryId(), k -> new ArrayList<>())
               .add(order);
        };
    }

    @Override
    public BinaryOperator<Map<Integer, List<Order>>> combiner() {
        return (map1, map2) -> {
            map2.forEach((key, value) ->
                map1.merge(key, value, (l1, l2) -> {
                    l1.addAll(l2);
                    return l1;
                })
            );
            return map1;
        };
    }

    @Override
    public Function<Map<Integer, List<Order>>, Map<Integer, List<Order>>> finisher() {
        return map -> map;
    }

    @Override
    public Set<Characteristics> characteristics() {
        return EnumSet.of(Characteristics.IDENTITY_FINISH);
    }
}
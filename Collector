------------ Collect to a comma-separated String ---------------
String result = list.stream().collect(
    Collector.of(
        StringBuilder::new,                     // Supplier
        (sb, s) -> sb.append(s).append(","),    // Accumulator
        (sb1, sb2) -> sb1.append(sb2),          // Combiner
        sb -> {                                 // Finisher
            if (sb.length() > 0) sb.setLength(sb.length() - 1); // to remove last comma
            return sb.toString();
        }
    )
);
